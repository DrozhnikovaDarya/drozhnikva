#include <iostream>
#include <windows.h>
#include <string>
#include <sstream>
#include <cmath>
#include <algorithm>

using namespace std;

main(){
    SetConsoleOutputCP(CP_UTF8);
    SetConsoleCP(CP_UTF8);
    int n;
    cout << "Введите кол-во точек: ";
    cin >> n;
    double t;

    int x[n] = {0}; 
    int y[n] = {0};
    int d[n] = {0};
    int k=0, T=0;

    for (int i = 0; i < n; i++) {
        double t1, t2;
        cout << "Введите координаты точки: ";
        cin >> t1 >> t2; 
        x[i] = t1;
        y[i] = t2;
        t = t1*t1 + t2*t2;
        d[i] = t;
        if (t > T){ T = t; k = i;}}
    cout << "Все точки:" << endl;
    for (int i = 0; i < n; i++) {
        cout << "(" << x[i] << "; " << y[i] << ") растояние в квадрате: " << d[i] << endl;}
    cout << "Максималное растояние от центра  точки (" << x[k] << "; " << y[k] << ") оно равно " << d[k] << endl;


    system("pause");
    return 0;
}
